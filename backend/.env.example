# ─── BANCO DE DADOS ───────────────────────────────────────────
# Preencha com as credenciais do seu PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=somotor
DB_USER=postgres
DB_PASS=sua_senha_aqui

# ─── AUTENTICAÇÃO ─────────────────────────────────────────────
# Troque por uma string longa e aleatória
JWT_SECRET=somotor_chave_secreta_2024_troque_isso

# ─── SERVIDOR ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── FRONTEND (CORS) ──────────────────────────────────────────
